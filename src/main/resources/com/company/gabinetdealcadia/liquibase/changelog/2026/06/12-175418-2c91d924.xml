<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="3" author="GabinetDeAlcadia">
        <createTable tableName="CATEGORIA">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_CATEGORIA"/>
            </column>
            <column name="nom" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="4" author="GabinetDeAlcadia">
        <createTable tableName="CONTACTE_CATEGORIA_LINK">
            <column name="ID_CATEGORIA" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_CONTACTE_CATEGORIA_LINK"/>
            </column>
            <column name="ID_CONTACTE" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_CONTACTE_CATEGORIA_LINK"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="5" author="GabinetDeAlcadia">
        <createTable tableName="ENTITAT_CATEGORIA_LINK">
            <column name="ID_CATEGORIA" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_ENTITAT_CATEGORIA_LINK"/>
            </column>
            <column name="ID_ENTITAT" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_ENTITAT_CATEGORIA_LINK"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="6" author="GabinetDeAlcadia">
        <addForeignKeyConstraint baseColumnNames="ID_CATEGORIA" baseTableName="CONTACTE_CATEGORIA_LINK"
                                 constraintName="FK_CONCAT_ON_CATEGORIA" referencedColumnNames="ID"
                                 referencedTableName="CATEGORIA"/>
    </changeSet>
    <changeSet id="7" author="GabinetDeAlcadia">
        <addForeignKeyConstraint baseColumnNames="ID_CONTACTE" baseTableName="CONTACTE_CATEGORIA_LINK"
                                 constraintName="FK_CONCAT_ON_CONTACTE" referencedColumnNames="id_contacte"
                                 referencedTableName="contacte"/>
    </changeSet>
    <changeSet id="8" author="GabinetDeAlcadia">
        <addForeignKeyConstraint baseColumnNames="ID_CATEGORIA" baseTableName="ENTITAT_CATEGORIA_LINK"
                                 constraintName="FK_ENTCAT_ON_CATEGORIA" referencedColumnNames="ID"
                                 referencedTableName="CATEGORIA"/>
    </changeSet>
    <changeSet id="9" author="GabinetDeAlcadia">
        <addForeignKeyConstraint baseColumnNames="ID_ENTITAT" baseTableName="ENTITAT_CATEGORIA_LINK"
                                 constraintName="FK_ENTCAT_ON_ENTITAT" referencedColumnNames="id_entitat"
                                 referencedTableName="entitat"/>
    </changeSet>
</databaseChangeLog>