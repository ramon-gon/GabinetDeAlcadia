    </changeSet>
    <changeSet id="7" author="GabinetDeAlcadia">
        <addColumn tableName="entitat">
            <column name="categoria" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>
    <changeSet id="8" author="GabinetDeAlcadia">
        <dropTable cascadeConstraints="true" tableName="categoria"/>
    </changeSet>
    <changeSet id="9" author="GabinetDeAlcadia">
        <dropTable cascadeConstraints="true" tableName="contacte_categoria_link"/>
    </changeSet>
    <changeSet id="10" author="GabinetDeAlcadia">
        <dropTable cascadeConstraints="true" tableName="entitat_categoria_link"/>
    </changeSet>
</databaseChangeLog>