<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://entitatListView.title"
      focusComponent="entitatsDataGrid">
    <data>
        <collection id="entitatsDc"
                    class="com.company.gabinetdealcadia.entity.Entitat">
            <fetchPlan extends="_base">
                <property name="categories" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="entitatsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Entitat e]]>
                </query>
            </loader>
        </collection>

        <collection id="filtreCategoriesDc"
                    class="com.company.gabinetdealcadia.entity.Categoria">
            <fetchPlan extends="_base"/>
            <loader id="filtreCategoriesDl" readOnly="true">
                <query>
                    <![CDATA[select c from Categoria c order by c.nom]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="entitatsDl"
                       autoApply="false">
            <configurations>
                <configuration id="filtreEntitats" default="true">
                    <propertyFilter property="nom"
                                    operation="CONTAINS"
                                    label="Nom Entitat"/>

                    <jpqlFilter parameterClass="java.util.UUID"
                                label="Filtra per Categoria"
                                parameterName="categoriaSeleccionada">
                        <condition>
                            <c:jpql>
                                <c:where><![CDATA[exists (select c from e.categories c where c.id = :categoriaSeleccionada)]]></c:where>
                            </c:jpql>
                        </condition>
                        <entityComboBox metaClass="Categoria"
                                        itemsContainer="filtreCategoriesDc"/>
                    </jpqlFilter>
                </configuration>
            </configurations>
        </genericFilter>

        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="entitatsDataGrid.createAction"/>
                <button id="readButton" action="entitatsDataGrid.readAction"/>
                <button id="editButton" action="entitatsDataGrid.editAction"/>
                <button id="removeButton" action="entitatsDataGrid.removeAction"/>

                <button id="exportaExcelBtn" action="entitatsDataGrid.excelExport"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="entitatsDl" autoLoad="false"/>
            </endSlot>
        </hbox>

        <dataGrid id="entitatsDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="entitatsDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="readAction" type="list_read"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>

                <action id="excelExport" type="grdexp_excelExport"/>
            </actions>
            <columns resizable="true">
                <column property="nom" header="Nom" autoWidth="true"/>
                <column key="presidentColumn" header="President" autoWidth="true"/>
                <column key="categoriesColumn" header="Categories" autoWidth="true"/>
                <column property="adrecaSeu" header="Adreça de la Seu" autoWidth="true"/>
                <column property="codiPostal" header="Codi Postal" autoWidth="true"/>
                <column property="poblacio" header="Població" autoWidth="true"/>
                <column property="pais" header="País" autoWidth="true"/>
                <column property="emailGeneral" header="Correu Electrònic General" autoWidth="true" flexGrow="1"/>
                <column property="telefonSeu" header="Telèfon de la Seu" autoWidth="true"/>
                <column property="comentariTelefonSeu" header="Comentaris del telèfon" autoWidth="true"/>
                <column property="activa" header="Activa" autoWidth="true"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>