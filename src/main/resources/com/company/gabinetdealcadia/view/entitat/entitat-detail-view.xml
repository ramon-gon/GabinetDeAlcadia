<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://entitatDetailView.title"
      focusComponent="form">
    <data>
        <instance id="entitatDc"
                  class="com.company.gabinetdealcadia.entity.Entitat">
            <fetchPlan extends="_base"/>
            <loader id="entitatDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="entitatDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <textField id="nomField" property="nom"/>
            <textField id="categoriaField" property="categoria"/>
            <textField id="adreçaSeuField" property="adreçaSeu"/>
            <textField id="codiPostalField" property="codiPostal"/>
            <textField id="poblacioField" property="poblacio"/>
            <textField id="paisField" property="pais"/>
            <textField id="emailGeneralField" property="emailGeneral"/>
            <textField id="telefonSeuField" property="telefonSeu"/>
            <checkbox id="activaField" property="activa"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
