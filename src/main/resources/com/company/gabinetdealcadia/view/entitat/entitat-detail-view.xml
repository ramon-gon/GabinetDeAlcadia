<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://entitatDetailView.title"
      focusComponent="form">
    <data>
        <instance id="entitatDc"
                  class="com.company.gabinetdealcadia.entity.Entitat">
            <fetchPlan extends="_base">
                <property name="categorias" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="entitatDl"/>
        </instance>

        <collection id="categoriasDc" class="com.company.gabinetdealcadia.entity.Categoria">
            <fetchPlan extends="_base"/>
            <loader id="categoriasDl">
                <query><![CDATA[select c from Categoria c order by c.nom asc]]></query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="entitatDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <textField id="nomField" property="nom" label="Nom"/>

            <multiSelectComboBox id="categoriasField"
                                 property="categorias"
                                 itemsContainer="categoriasDc"
                                 label="Categories"/>

            <textField id="adreçaSeuField" property="adreçaSeu" label="Adreça de la Seu"/>
            <textField id="codiPostalField" property="codiPostal" label="Codi Postal"/>
            <textField id="poblacioField" property="poblacio" label="Població"/>
            <textField id="paisField" property="pais" label="País"/>
            <textField id="emailGeneralField" property="emailGeneral" label="Correu Electrònic General"/>
            <textField id="telefonSeuField"
                       property="telefonSeu"
                       label="Telèfon de la Seu"
                       allowedCharPattern="[0-9]"/>
            <textField id="comentariTelefonSeuField" property="comentariTelefonSeu" label="Comentaris del telèfon"/>
            <checkbox id="activaField" property="activa" label="Activa"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>