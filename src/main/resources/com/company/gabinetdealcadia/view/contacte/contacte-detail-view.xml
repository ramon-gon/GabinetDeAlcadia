<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://contacteDetailView.title"
      focusComponent="form">
    <data>
        <instance id="contacteDc"
                  class="com.company.gabinetdealcadia.entity.Contacte">
            <fetchPlan extends="_base">
                <property name="categories" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="contacteDl"/>
        </instance>

        <collection id="categoriasDc" class="com.company.gabinetdealcadia.entity.Categoria">
            <fetchPlan extends="_base"/>
            <loader id="categoriasDl">
                <query><![CDATA[select c from Categoria c order by c.nom asc]]></query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <vbox id="mainBox">

            <h3>Dades del Contacte</h3>
            <formLayout id="form" dataContainer="contacteDc">
                <responsiveSteps>
                    <responsiveStep minWidth="0" columns="1"/>
                    <responsiveStep minWidth="40em" columns="2"/>
                </responsiveSteps>

                <textField id="nomField" property="nom" label="Nom"/>
                <textField id="primerCognomField" property="primer_cognom" label="Primer Cognom"/>
                <textField id="segonCognomField" property="segon_cognom" label="Segon Cognom"/>

                <textArea id="carrecEntitatNomField"
                          label="Entitats Vinculades"
                          readOnly="true"
                          minHeight="4em"/>

                <textArea id="entitatCategoriesField"
                          label="Categories de les Entitats"
                          readOnly="true"
                          minHeight="4em"/>

                <multiSelectComboBox id="categoriesField"
                                     property="categories"
                                     itemsContainer="categoriasDc"
                                     label="Categories del Contacte"/>

                <textArea id="carrecTitolField"
                          label="Títols dels Càrrecs"
                          readOnly="true"
                          minHeight="4em"/>

                <select id="sexeField" property="sexe" label="Sexe"/>
                <datePicker id="dataNaixementField" property="dataNaixement" label="Data de Naixement"/>

            </formLayout>

            <hr/>

            <h3>Dades del Didn't / Cònjuge</h3>
            <formLayout id="formConjuge" dataContainer="contacteDc">
                <responsiveSteps>
                    <responsiveStep minWidth="0" columns="1"/>
                    <responsiveStep minWidth="40em" columns="2"/>
                </responsiveSteps>
                <textField id="nomConjugeField" property="nomConjuge" label="Nom del Cònjuge"/>
                <textField id="primerCognomConjugeField" property="primerCognomConjuge" label="Primer Cognom"/>
                <textField id="segonCognomConjugeField" property="segon_cognom" label="Segon Cognom"/>
                <select id="sexeConjugeField" property="sexeConjuge" label="Sexe del Cònjuge"/>
            </formLayout>

            <hr/>

            <h3>Dades de Contacte i Particulars</h3>
            <formLayout id="formContacte" dataContainer="contacteDc">
                <responsiveSteps>
                    <responsiveStep minWidth="0" columns="1"/>
                    <responsiveStep minWidth="40em" columns="2"/>
                </responsiveSteps>
                <textField id="emailPersonalField" property="emailPersonal" label="Correu Electrònic Personal"/>
                <textField id="telefonMobilField" property="telefonMobil" label="Telèfon Mòbil" allowedCharPattern="[0-9]"/>
                <textField id="comentariTelefonMobilField" property="comentariTelefonMobil" label="Comentaris del telèfon"/>
                <textField id="adreçaParticularField" property="adreçaParticular" label="Adreça Particular"/>
                <textField id="codiPostalParticularField" property="codiPostalParticular" allowedCharPattern="[0-9]" label="Codi Postal Particular"/>
                <textField id="poblacioParticularField" property="poblacioParticular" label="Població Particular"/>
                <textArea id="observacionsHistoriquesField" property="observacionsHistoriques" label="Observacions Històriques"/>
            </formLayout>

        </vbox>

        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>