<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://contacteListView.title"
      focusComponent="contactesDataGrid">
    <data>
        <collection id="contactesDc"
                    class="com.company.gabinetdealcadia.entity.Contacte">
            <fetchPlan extends="_base">
                <property name="categories" fetchPlan="_base"/>
                <property name="carrec" fetchPlan="_base">
                    <property name="entitat" fetchPlan="_base"/>
                </property>
            </fetchPlan>
            <loader id="contactesDl" readOnly="true">
                <query>
                    <![CDATA[select e from Contacte e]]>
                </query>
            </loader>
        </collection>

        <collection id="entitatsDc"
                    class="com.company.gabinetdealcadia.entity.Entitat">
            <fetchPlan extends="_base"/>
            <loader id="entitatsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Entitat e order by e.nom]]>
                </query>
            </loader>
        </collection>

        <collection id="categoriasDc"
                    class="com.company.gabinetdealcadia.entity.Categoria">
            <fetchPlan extends="_base"/>
            <loader id="categoriasDl" readOnly="true">
                <query>
                    <![CDATA[select c from Categoria c order by c.nom]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="contactesDl"
                       autoApply="false">
            <configurations>
                <configuration id="filtrePredefinit" default="true">
                    <jpqlFilter parameterClass="java.lang.String"
                                label="Cerca Nom"
                                parameterName="cercaNomComplet">
                        <condition>
                            <c:jpql>
                                <c:where><![CDATA[
                                    lower(concat(
                                        coalesce(e.nom, ''), ' ',
                                        coalesce(e.primer_cognom, ''), ' ',
                                        coalesce(e.segon_cognom, '')
                                    )) like lower(concat('%', :cercaNomComplet, '%'))
                                ]]></c:where>
                            </c:jpql>
                        </condition>
                    </jpqlFilter>

                    <jpqlFilter parameterClass="java.util.UUID"
                                label="Filtra per Entitat"
                                parameterName="entitatSeleccionada">
                        <condition>
                            <c:jpql>
                                <c:where><![CDATA[exists (select c from Carrec c where c.contacte = e and c.entitat.id = :entitatSeleccionada)]]></c:where>
                            </c:jpql>
                        </condition>
                        <entityComboBox metaClass="Entitat"
                                        itemsContainer="entitatsDc"/>
                    </jpqlFilter>

                    <jpqlFilter parameterClass="java.util.UUID"
                                label="Filtra per Categoria"
                                parameterName="categoriaSeleccionada">
                        <condition>
                            <c:jpql>
                                <c:where><![CDATA[
                                    exists (select cat from e.categories cat where cat.id = :categoriaSeleccionada)
                                    or
                                    exists (select c from Carrec c join c.entitat ent join ent.categories entCat where c.contacte = e and entCat.id = :categoriaSeleccionada)
                                ]]></c:where>
                            </c:jpql>
                        </condition>
                        <entityComboBox metaClass="Categoria"
                                        itemsContainer="categoriasDc"/>
                    </jpqlFilter>
                </configuration>
            </configurations>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="contactesDataGrid.createAction"/>
                <button id="readButton" action="contactesDataGrid.readAction"/>
                <button id="editButton" action="contactesDataGrid.editAction"/>
                <button id="removeButton" action="contactesDataGrid.removeAction"/>

                <button id="exportaExcelBtn" action="contactesDataGrid.excelExport"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination"
                                  dataLoader="contactesDl"
                                  autoLoad="false"/>
            </endSlot>
        </hbox>
        <dataGrid id="contactesDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="contactesDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="readAction" type="list_read"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>

                <action id="excelExport" type="grdexp_excelExport"/>
            </actions>
            <columns resizable="true">
                <column key="nomcompletcontacte" header="Nom del Contacte" autoWidth="true"/>
                <column key="entitatpertanyent" header="Entitat" autoWidth="true"/>
                <column key="categoriesColumn" header="Categories" autoWidth="true"/>

                <column property="sexe" header="Sexe" autoWidth="true"/>
                <column property="dataNaixement" header="Data de Naixement" autoWidth="true"/>
                <column property="nomConjuge" header="Nom del Cònjuge" autoWidth="true"/>
                <column property="sexeConjuge" header="Sexe del Cònjuge" autoWidth="true"/>
                <column property="emailPersonal" header="Correu Electrònic Personal" autoWidth="true"/>
                <column property="telefonMobil" header="Telèfon Mòbil" autoWidth="true"/>
                <column property="comentariTelefonMobil" header="Comentaris del telèfon" autoWidth="true"/>
                <column property="adrecaParticular" header="Adreça Particular" autoWidth="true"/>
                <column property="codiPostalParticular" header="Codi Postal Particular" autoWidth="true"/>
                <column property="poblacioParticular" header="Població Particular" autoWidth="true"/>
                <column property="observacionsHistoriques" header="Observacions Històriques" autoWidth="true" flexGrow="1"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>