<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://carrecDetailView.title"
      focusComponent="form">
    <data>
        <instance id="carrecDc"
                  class="com.company.gabinetdealcadia.entity.Carrec">
            <fetchPlan extends="_base">
                <property name="contacte" fetchPlan="_base"/>
                <property name="entitat" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="carrecDl"/>
        </instance>
        <collection id="contactesDc" class="com.company.gabinetdealcadia.entity.Contacte">
            <loader id="contactesDl" readOnly="true">
                <query><![CDATA[select e from Contacte e order by e.nom]]></query>
            </loader>
        </collection>
        <collection id="entitatsDc" class="com.company.gabinetdealcadia.entity.Entitat">
            <loader id="entitatsDl" readOnly="true">
                <query><![CDATA[select e from Entitat e order by e.nom]]></query>
            </loader>
        </collection>
    </data>

    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>

    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>

    <layout>
        <formLayout id="form" dataContainer="carrecDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>

            <entityComboBox id="contacteField"
                            property="contacte"
                            label="Contacte"
                            itemsContainer="contactesDc"/>

            <entityComboBox id="entitatField"
                            property="entitat"
                            label="Entitat"
                            itemsContainer="entitatsDc"/>

            <textField id="titolCarrecField"
                       property="titolCarrec"
                       label="Títol Càrrec"/>

            <checkbox id="vigentField"
                      property="vigent"
                      label="Vigent"/>

            <textField id="telefonDirecteField"
                       property="telefonDirecte"
                       label="Telèfon Directe"/>

            <emailField id="emailCorporatiuField"
                        property="emailCorporatiu"
                        label="Email Corporatiu"
                        errorMessage="Per favor, introdueix un correu electrònic vàlid"/>

            <checkbox id="puntTramesesField"
                      property="puntTrameses"
                      label="Punt de Trameses"/>

            <textField id="comentariTelefonField"
                       property="comentariTelefon"
                       label="Comentari Telèfon"/>

            <textArea id="observacionsCarrecField"
                      height="9.5em"
                      property="observacionsCarrec"
                      label="Observacions"/>
        </formLayout>

        <hbox id="detailActions" classNames="buttons-panel">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>