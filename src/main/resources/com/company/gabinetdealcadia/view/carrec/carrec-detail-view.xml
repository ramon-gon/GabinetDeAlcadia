<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://carrecDetailView.title"
      focusComponent="form">
    <data>
        <instance id="carrecDc"
                  class="com.company.gabinetdealcadia.entity.Carrec">
            <fetchPlan extends="_base"/>
            <loader id="carrecDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="carrecDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <textField id="titolCarrecField" property="titolCarrec"/>
            <checkbox id="vigentField" property="vigent"/>
            <textField id="telefonDirecteField" property="telefonDirecte"/>
            <textField id="emailCorporatiuField" property="emailCorporatiu"/>
            <checkbox id="puntTramesesField" property="puntTrameses"/>
            <textArea id="observacionsCarrecField" height="9.5em" property="observacionsCarrec"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
