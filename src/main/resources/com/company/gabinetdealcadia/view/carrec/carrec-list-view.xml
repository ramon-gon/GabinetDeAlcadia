<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://carrecListView.title"
      focusComponent="contactesDataGrid">
    <data>
        <collection id="contactesDc"
                    class="com.company.gabinetdealcadia.entity.Contacte">
            <fetchPlan extends="_base">
                <property name="categories" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="contactesDl" readOnly="true">
                <query>
                    <![CDATA[select e from Contacte e order by e.nom asc]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="contactesDl"
                       autoApply="false">
            <configurations>
                <configuration id="filtrePredefinit" default="true">
                    <jpqlFilter parameterClass="java.lang.String"
                                label="Contacte"
                                parameterName="cercaNomComplet">
                        <condition>
                            <c:jpql>
                                <c:where><![CDATA[
                                    lower(concat(
                                        coalesce(e.nom, ''), ' ',
                                        coalesce(e.primer_cognom, ''), ' ',
                                        coalesce(e.segon_cognom, '')
                                    )) like lower(concat('%', :cercaNomComplet, '%'))
                                ]]></c:where>
                            </c:jpql>
                        </condition>
                    </jpqlFilter>
                </configuration>
            </configurations>
        </genericFilter>

        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="contactesDataGrid.createAction"/>
                <button id="editButton" action="contactesDataGrid.editAction"/>
                <button id="removeButton" action="contactesDataGrid.removeAction"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="contactesDl"/>
            </endSlot>
        </hbox>

        <dataGrid id="contactesDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="contactesDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column key="nomCompletContacte" header="Contacte" autoWidth="true"/>

                <column key="cargosAgrupados" header="Càrrecs i Entitats" autoWidth="true" flexGrow="1"/>

                <column property="emailPersonal" header="Correu Personal" autoWidth="true"/>
                <column property="telefonMobil" header="Telèfon Mòbil" autoWidth="true"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>