<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="Carrecs"
      focusComponent="carrecsDataGrid">
    <data>
        <collection id="carrecsDc" class="com.company.gabinetdealcadia.entity.Carrec">
            <fetchPlan extends="_base">
                <property name="contacte" fetchPlan="_base"/>
                <property name="entitat" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="carrecsDl" readOnly="true">
                <query><![CDATA[select e from Carrec e]]></query>
            </loader>
        </collection>

        <collection id="filtreEntitatsDc"
                    class="com.company.gabinetdealcadia.entity.Entitat">
            <fetchPlan extends="_base"/>
            <loader id="filtreEntitatsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Entitat e order by e.nom]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="carrecsDl"
                       autoApply="false">
            <configurations>
                <configuration id="filtreCarrecs" default="true">
                    <jpqlFilter parameterClass="java.lang.String"
                                label="Cerca Nom Contacte"
                                parameterName="cercaNomComplet">
                        <condition>
                            <c:jpql>
                                <c:where><![CDATA[
                                    lower(concat(
                                        coalesce({E}.contacte.nom, ''), ' ',
                                        coalesce({E}.contacte.primer_cognom, ''), ' ',
                                        coalesce({E}.contacte.segon_cognom, '')
                                    )) like lower(concat('%', :cercaNomComplet, '%'))
                                ]]></c:where>
                            </c:jpql>
                        </condition>
                    </jpqlFilter>

                    <jpqlFilter parameterClass="java.util.UUID"
                                label="Filtra per Entitat"
                                parameterName="entitatSeleccionada">
                        <condition>
                            <c:jpql>
                                <c:where><![CDATA[{E}.entitat.id = :entitatSeleccionada]]></c:where>
                            </c:jpql>
                        </condition>
                        <entityComboBox metaClass="Entitat"
                                        itemsContainer="filtreEntitatsDc"/>
                    </jpqlFilter>
                </configuration>
            </configurations>
        </genericFilter>

        <hbox classNames="buttons-panel">
            <button id="createButton" action="carrecsDataGrid.createAction"/>
            <button id="readButton" action="carrecsDataGrid.readAction"/>
            <button id="editButton" action="carrecsDataGrid.editAction"/>
            <button id="removeButton" action="carrecsDataGrid.removeAction"/>

            <button id="exportaExcelBtn" action="carrecsDataGrid.excelExport"/>
        </hbox>

        <dataGrid id="carrecsDataGrid"
                  dataContainer="carrecsDc"
                  width="100%"
                  height="100%"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="readAction" type="list_read"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>

                <action id="excelExport" type="grdexp_excelExport"/>
            </actions>
            <columns resizable="true">
                <column property="titolCarrec" header="Títol" autoWidth="true"/>
                <column property="contacte" header="Contacte" autoWidth="true"/>
                <column property="entitat" header="Entitat" autoWidth="true"/>
                <column property="telefonDirecte" header="Telèfon" autoWidth="true"/>
                <column property="emailCorporatiu" header="Email" autoWidth="true"/>
                <column property="puntTrameses" header="Punt de Trameses" autoWidth="true"/>
                <column property="vigent" header="Vigent" autoWidth="true"/>
            </columns>
        </dataGrid>
    </layout>
</view>