<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://categoriaDetailView.title"
      focusComponent="form">
    <data>
        <instance id="categoriaDc"
                  class="com.company.gabinetdealcadia.entity.Categoria">
            <fetchPlan extends="_base"/>
            <loader id="categoriaDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="categoriaDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <textField id="nomField" property="nom" label="Nom de la Categoria" width="100%"/>
        </formLayout>
        <hbox id="detailActions" classNames="buttons-panel">
            <button id="saveAndCloseButton" action="saveCloseAction" themeNames="primary"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>