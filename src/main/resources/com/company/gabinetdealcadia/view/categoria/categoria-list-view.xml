<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://categoriaListView.title"
      focusComponent="categoriasDataGrid">
    <data>
        <collection id="categoriasDc"
                    class="com.company.gabinetdealcadia.entity.Categoria">
            <fetchPlan extends="_base"/>
            <loader id="categoriasDl" readOnly="true">
                <query>
                    <![CDATA[select e from Categoria e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <!-- Filtre net: l'esquema vàlid de Jmix necessita les etiquetes en aquest ordre exacte -->
        <genericFilter id="genericFilter"
                       dataLoader="categoriasDl"
                       opened="true">
            <properties include="nom"/>
            <configurations>
                <configuration id="defaultConfiguration" default="true">
                    <propertyFilter property="nom"
                                    operation="CONTAINS"
                                    label="Filtra per nom:"
                    />
                </configuration>
            </configurations>
        </genericFilter>

        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="categoriasDataGrid.createAction"/>
                <button id="editButton" action="categoriasDataGrid.editAction"/>
                <button id="removeButton" action="categoriasDataGrid.removeAction"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="categoriasDl"/>
            </endSlot>
        </hbox>

        <dataGrid id="categoriasDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="categoriasDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="nom" header="Nom"/>
            </columns>
        </dataGrid>

        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>